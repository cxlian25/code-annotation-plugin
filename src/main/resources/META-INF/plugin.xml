<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <id>com.example.code-annotation-plugin</id>
  <name>Code Annotation Plugins</name>
  <vendor email="cxlian25@foxmail.com">cxlian</vendor>

  <description><![CDATA[
    A code annotation assistant panel on the right side of the IDE.
    This version provides a ToolWindow skeleton with clickable buttons for further business logic.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.java</depends>

  <extensions defaultExtensionNs="com.intellij">
    <toolWindow id="Code Annotation"
                anchor="right"
                icon="/META-INF/pluginIcon.svg"
                factoryClass="com.example.codeannotationplugin.CodeAnnotationToolWindowFactory"
                canCloseContents="false"/>
  </extensions>

  <actions>
    <action id="OpenCodeAnnotationToolWindow"
            class="com.example.codeannotationplugin.OpenCodeAnnotationToolWindowAction"
            text="Open Code Annotation Panel"
            description="Open the Code Annotation tool window">
      <add-to-group group-id="ToolsMenu" anchor="first"/>
    </action>
  </actions>
</idea-plugin>