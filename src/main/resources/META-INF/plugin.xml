<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <id>com.example.code-annotation-plugin</id>
  <name>代码注释插件</name>
  <vendor email="cxlian25@foxmail.com">cxlian</vendor>

  <description><![CDATA[
    IDE 右侧的代码注释助手面板。
    当前版本提供可点击按钮的 ToolWindow 基础能力。
  ]]></description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.java</depends>

  <extensions defaultExtensionNs="com.intellij">
    <toolWindow id="代码注释"
                anchor="right"
                icon="/META-INF/pluginIcon.svg"
                factoryClass="com.example.codeannotationplugin.CodeAnnotationToolWindowFactory"
                canCloseContents="false"/>
  </extensions>

  <actions>
    <action id="OpenCodeAnnotationToolWindow"
            class="com.example.codeannotationplugin.OpenCodeAnnotationToolWindowAction"
            text="打开代码注释面板"
            description="打开代码注释工具窗口">
      <add-to-group group-id="ToolsMenu" anchor="first"/>
    </action>
  </actions>
</idea-plugin>